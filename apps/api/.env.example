# ============================================================
# Security Buddy API — required environment variables
# Copy to .env and fill in real values. DO NOT commit .env.
# Missing any REQUIRED variable causes startup failure.
# ============================================================

# --- REQUIRED (no defaults; service refuses to start if missing) ---

# Postgres connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://security_buddy:security_buddy@localhost:5432/security_buddy

# Redis connection string
REDIS_URL=redis://localhost:6379/0

# OpenRouter API key — get from https://openrouter.ai/keys
OPENROUTER_API_KEY=replace-me-no-default

# LangSmith tracing — set to DISABLED to skip tracing
LANGSMITH_API_KEY=replace-me-or-DISABLED

# LangSmith project name
LANGSMITH_PROJECT=security-buddy

# Session secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=replace-me-32-byte-hex

# --- OPTIONAL (Slice 1+ — leave blank for Slice 0) ---

# Target system (OpenEMR Clinical Co-Pilot)
TARGET_BASE_URL=
TARGET_LOGIN_USER=
TARGET_LOGIN_PASSWORD=

# GitHub PAT — scoped to OpenEMR fork ONLY, repo scope
GITHUB_PAT=
